<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lantern Isle: Guardian Star</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <script async src="https://vibej.am/2026/widget.js"></script>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#1a1228;overflow:hidden;font-family:'Nunito',sans-serif;width:100vw;height:100vh;}
    canvas{display:block;}
    #ui{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:10;}
    #hud-crystals{position:absolute;top:12px;left:12px;display:flex;align-items:center;gap:6px;
      background:rgba(240,222,194,0.82);border:1.5px solid #4F4261;border-radius:20px;
      padding:6px 12px;pointer-events:auto;}
    .gem{width:22px;height:26px;position:relative;}
    .gem svg{width:100%;height:100%;}
    #crystal-label{font-size:12px;font-weight:700;color:#4F4261;margin-left:4px;}
    #hud-compass{position:absolute;top:12px;right:12px;width:88px;height:88px;pointer-events:auto;}
    #hud-compass canvas{border-radius:50%;border:3px solid #EBB21A;box-shadow:0 0 0 2px #F0DEC2;}
    #inventory{position:absolute;right:12px;top:50%;transform:translateY(-50%);
      display:flex;flex-direction:column;gap:6px;pointer-events:auto;}
    .inv-slot{width:44px;height:44px;background:rgba(240,222,194,0.8);
      border:1.5px solid #4F4261;border-radius:6px;display:flex;align-items:center;
      justify-content:center;font-size:18px;}
    #dialogue-box{position:absolute;bottom:0;left:0;width:100%;height:22%;
      background:#F0DEC2;border-top:3px solid #EB6259;display:none;pointer-events:auto;
      box-shadow:0 -4px 18px rgba(79,66,97,0.18);}
    #dialogue-floral-left{position:absolute;top:-18px;left:10px;font-size:28px;color:#EB6259;}
    #dialogue-floral-right{position:absolute;top:-18px;right:10px;font-size:28px;color:#EB6259;}
    #dialogue-speaker{position:absolute;top:-14px;left:20px;background:#EB6259;
      color:#F0DEC2;font-weight:700;font-size:12px;padding:3px 12px;border-radius:12px;
      box-shadow:0 2px 6px rgba(79,66,97,0.25);}
    #dialogue-text{padding:20px 60px 14px 20px;font-size:14px;line-height:1.7;color:#4F4261;}
    #dialogue-continue{position:absolute;bottom:12px;right:18px;font-size:18px;
      color:#EB6259;cursor:pointer;animation:bob 0.6s ease-in-out infinite alternate;}
    @keyframes bob{from{transform:translateY(0)}to{transform:translateY(5px)}}
    #map-screen{position:absolute;inset:0;background:rgba(240,222,194,0.97);
      display:none;flex-direction:column;align-items:center;justify-content:center;
      pointer-events:auto;z-index:20;}
    #map-title{font-size:36px;font-weight:800;color:#4F4261;margin-bottom:20px;
      text-shadow:2px 2px 0 rgba(240,222,194,0.8);}
    #map-canvas{border:4px solid #D4836A;border-radius:18px;background:#F0DEC2;}
    #close-map{margin-top:14px;background:#EB6259;color:#F0DEC2;border:none;
      font-family:'Nunito',sans-serif;font-size:15px;font-weight:700;
      padding:8px 28px;border-radius:12px;cursor:pointer;pointer-events:auto;}
    #title-screen{position:absolute;inset:0;
      background:linear-gradient(180deg,#2A1A4A 0%,#4F3A7A 40%,#9B9AE2 80%,#F0DEC2 100%);
      transition:opacity 0.35s ease;display:flex;flex-direction:column;align-items:center;
      justify-content:center;z-index:30;pointer-events:auto;overflow:hidden;}
    #title-lantern{font-size:56px;animation:lanternFloat 2.5s ease-in-out infinite alternate;
      filter:drop-shadow(0 0 18px rgba(235,178,26,0.8));margin-bottom:8px;}
    @keyframes lanternFloat{from{transform:translateY(0) rotate(-4deg)}to{transform:translateY(-12px) rotate(4deg)}}
    #title-screen h1{font-size:42px;font-weight:800;color:#F0DEC2;text-align:center;
      line-height:1.2;text-shadow:0 0 24px rgba(235,178,26,0.6),0 2px 8px rgba(0,0,0,0.4);}
    #title-tagline{color:#EBB21A;font-size:14px;margin-top:6px;font-weight:600;
      letter-spacing:1.5px;text-transform:uppercase;opacity:0.9;}
    #title-screen p{color:#C6C3DC;font-size:14px;margin-top:10px;opacity:0.85;
      max-width:320px;text-align:center;line-height:1.6;}
    #start-btn{margin-top:28px;background:linear-gradient(135deg,#EBB21A,#EB6259);color:#1a1228;border:none;
      font-family:'Nunito',sans-serif;font-size:17px;font-weight:800;
      padding:13px 42px;border-radius:14px;cursor:pointer;
      box-shadow:0 4px 20px rgba(235,178,26,0.5);transition:transform 0.15s,box-shadow 0.15s;}
    #start-btn:hover{transform:scale(1.06);box-shadow:0 6px 28px rgba(235,178,26,0.7);}
    #reset-btn{margin-top:12px;background:transparent;color:#4F4261;border:1.5px solid #4F4261;
      font-family:'Nunito',sans-serif;font-size:13px;font-weight:600;
      padding:7px 22px;border-radius:10px;cursor:pointer;opacity:0.7;}
    #reset-btn:hover{opacity:1;background:rgba(79,66,97,0.08);}
    #dev-btn{margin-top:6px;background:transparent;color:#9B9AE2;border:1.5px dashed #9B9AE2;
      font-family:'Nunito',sans-serif;font-size:11px;font-weight:600;
      padding:5px 16px;border-radius:10px;cursor:pointer;opacity:0.5;}
    #dev-btn:hover{opacity:1;}
    #sound-toggle{position:absolute;top:12px;right:116px;background:rgba(240,222,194,0.82);
      border:1.5px solid #4F4261;border-radius:20px;padding:6px 10px;
      cursor:pointer;pointer-events:auto;font-size:18px;}
    #ability-bar{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);
      display:flex;gap:8px;pointer-events:none;}
    .ability-slot{width:38px;height:38px;background:rgba(240,222,194,0.82);
      border:1.5px solid #4F4261;border-radius:8px;display:flex;align-items:center;
      justify-content:center;font-size:16px;position:relative;}
    .ability-cooldown{position:absolute;inset:0;background:rgba(79,66,97,0.5);
      border-radius:7px;transform-origin:bottom;transition:transform 0.1s;}
    #win-screen{position:absolute;inset:0;background:radial-gradient(ellipse at center,#2A1A4A 0%,#1a1228 100%);
      display:none;flex-direction:column;align-items:center;justify-content:center;
      z-index:40;pointer-events:auto;overflow:hidden;}
    #win-stars{position:absolute;inset:0;pointer-events:none;}
    #win-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;
      padding:20px;text-align:center;}
    #win-screen h1{font-size:38px;font-weight:800;color:#EBB21A;text-align:center;
      text-shadow:0 0 30px rgba(235,178,26,0.8),0 2px 4px rgba(0,0,0,0.5);line-height:1.3;}
    #win-screen p{color:#F0DEC2;margin-top:14px;font-size:15px;max-width:480px;
      line-height:1.9;text-shadow:0 1px 3px rgba(0,0,0,0.5);}
    #restart-btn{margin-top:28px;background:linear-gradient(135deg,#EBB21A,#EB6259);color:#1a1228;
      border:none;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;
      padding:12px 36px;border-radius:14px;cursor:pointer;box-shadow:0 4px 20px rgba(235,178,26,0.5);}
    #restart-btn:hover{transform:scale(1.05);}
    #restore-flash{position:fixed;inset:0;background:white;opacity:0;pointer-events:none;z-index:45;
      transition:opacity 0.12s ease;}
    #grain{position:fixed;inset:0;pointer-events:none;z-index:50;opacity:0.09;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size:200px 200px;}
    #mobile-controls{position:absolute;bottom:0;left:0;width:100%;height:200px;
      display:none;pointer-events:auto;}
    #joystick-zone{position:absolute;bottom:20px;left:20px;width:120px;height:120px;
      border-radius:50%;background:rgba(240,222,194,0.2);border:2px solid rgba(240,222,194,0.4);}
    #joystick-knob{position:absolute;width:50px;height:50px;border-radius:50%;
      background:rgba(235,98,89,0.6);top:50%;left:50%;transform:translate(-50%,-50%);}
    #action-btn{position:absolute;bottom:30px;right:30px;width:70px;height:70px;
      border-radius:50%;background:rgba(235,98,89,0.7);border:2px solid #F0DEC2;
      display:flex;align-items:center;justify-content:center;
      font-size:24px;color:#F0DEC2;font-weight:700;}
    #map-btn{position:absolute;top:12px;left:50%;transform:translateX(-50%);
      background:rgba(240,222,194,0.82);border:1.5px solid #4F4261;border-radius:20px;
      padding:6px 16px;cursor:pointer;pointer-events:auto;font-size:13px;
      font-family:'Nunito',sans-serif;font-weight:700;color:#4F4261;}
    @media(max-width:480px){
      #hud-crystals{top:8px;left:8px;padding:4px 8px;gap:4px;}
      .gem{width:16px;height:20px;}
      #crystal-label{font-size:10px;}
      #hud-compass{top:8px;right:8px;width:60px;height:60px;}
      #hud-compass canvas{width:54px;height:54px;}
      #sound-toggle{top:8px;right:76px;padding:4px 8px;font-size:14px;}
      #map-btn{top:8px;left:50%;font-size:11px;padding:4px 10px;}
      #mobile-controls{height:180px;}
      #joystick-zone{width:100px;height:100px;bottom:16px;left:16px;}
      #joystick-knob{width:40px;height:40px;}
      #action-btn{width:58px;height:58px;font-size:20px;bottom:24px;right:24px;}
    }
    #interact-prompt{position:absolute;display:none;pointer-events:none;
      background:rgba(79,66,97,0.82);color:#F0DEC2;font-family:'Nunito',sans-serif;
      font-size:12px;font-weight:700;padding:4px 10px;border-radius:10px;
      border:1.5px solid #EBB21A;white-space:nowrap;transform:translate(-50%,-100%);
      animation:promptbob 0.7s ease-in-out infinite alternate;}
    @keyframes promptbob{from{transform:translate(-50%,-100%) translateY(0)}to{transform:translate(-50%,-100%) translateY(-4px)}}
    #transition-overlay{position:fixed;inset:0;background:#1a1228;opacity:0;pointer-events:none;
      z-index:35;transition:opacity 0.35s ease;}
    #island-banner{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.85);
      background:rgba(240,222,194,0.95);border:3px solid #EBB21A;border-radius:20px;
      padding:18px 40px;text-align:center;pointer-events:none;z-index:36;
      opacity:0;transition:opacity 0.3s ease,transform 0.3s ease;box-shadow:0 8px 32px rgba(79,66,97,0.35);}
    #island-banner.show{opacity:1;transform:translate(-50%,-50%) scale(1);}
    #island-banner h2{font-size:26px;font-weight:800;color:#4F4261;margin:0;}
    #island-banner p{font-size:13px;color:#EB6259;font-weight:600;margin-top:4px;}
    #quest-tracker{position:absolute;left:12px;top:50%;transform:translateY(-50%);
      background:rgba(240,222,194,0.88);border:1.5px solid #4F4261;border-radius:14px;
      padding:10px 14px;min-width:150px;max-width:200px;display:none;pointer-events:none;}
    #quest-tracker h4{font-size:11px;font-weight:800;color:#EB6259;text-transform:uppercase;
      letter-spacing:0.5px;margin-bottom:6px;}
    #quest-tracker ul{list-style:none;padding:0;margin:0;}
    #quest-tracker li{font-size:11px;color:#4F4261;font-weight:600;padding:2px 0;
      display:flex;align-items:center;gap:4px;}
    #quest-tracker li.done{opacity:0.45;text-decoration:line-through;}
  </style>
</head>
<body>
<div id="grain"></div>
<canvas id="game-canvas"></canvas>
<div id="transition-overlay"></div>
<div id="island-banner"><h2 id="island-banner-name"></h2><p id="island-banner-sub"></p></div>
<div id="ui">
  <div id="title-screen">
    <div id="title-lantern">🏮</div>
    <h1>Lantern Isle<br>Guardian Star</h1>
    <div id="title-tagline">A Cozy Island Adventure</div>
    <p>Six islands. Six shrines. One lantern bearer.<br>Can you reawaken the Guardian Star?</p>
    <button id="start-btn">✨ Begin Adventure</button>
    <button id="reset-btn">Start Over</button>
    <button id="dev-btn">🛠️ Dev Mode</button>
  </div>
  <div id="hud-crystals" style="display:none;">
    <div class="gem" id="gem0"></div>
    <div class="gem" id="gem1"></div>
    <div class="gem" id="gem2"></div>
    <div class="gem" id="gem3"></div>
    <div class="gem" id="gem4"></div>
    <span id="crystal-label">Crystals 0/5</span>
  </div>
  <button id="sound-toggle" style="display:none;">🔊</button>
  <button id="map-btn" style="display:none;">🗺️ Map</button>
  <div id="hud-compass" style="display:none;"><canvas id="compass-canvas" width="82" height="82"></canvas></div>
  <div id="inventory" style="display:none;">
    <div class="inv-slot">🏮</div>
    <div class="inv-slot" id="inv1"></div>
    <div class="inv-slot" id="inv2"></div>
  </div>
  <div id="quest-tracker">
    <h4>📜 Quests</h4>
    <ul id="quest-list"></ul>
  </div>
  <div id="ability-bar" style="display:none;">
    <div class="ability-slot" id="ab-pulse" title="Lantern Pulse [Q]" style="display:none;">💫<div class="ability-cooldown" style="transform:scaleY(0);"></div></div>
    <div class="ability-slot" id="ab-sprint" title="Sprint [Shift]" style="display:none;">💨<div class="ability-cooldown" style="transform:scaleY(0);"></div></div>
  </div>
  <div id="dialogue-box">
    <div id="dialogue-floral-left">❀</div>
    <div id="dialogue-floral-right">❀</div>
    <div id="dialogue-speaker">???</div>
    <div id="dialogue-text"></div>
    <div id="dialogue-continue">▼</div>
  </div>
  <div id="map-screen">
    <div id="map-title">✨ World Map ✨</div>
    <canvas id="map-canvas" width="640" height="400"></canvas>
    <button id="close-map">Close Map</button>
  </div>
  <div id="interact-prompt">Press E</div>
  <div id="win-screen">
    <canvas id="win-stars"></canvas>
    <div id="win-content">
      <h1>✨ The Guardian Star<br>is Reawakened! ✨</h1>
      <p id="win-epilogue"></p>
      <button id="restart-btn">Play Again</button>
    </div>
  </div>
  <div id="restore-flash"></div>
</div>
<div id="mobile-controls" style="display:none;">
  <div id="joystick-zone"><div id="joystick-knob"></div></div>
  <div id="action-btn">E</div>
</div>
<script type="module" src="src/game.js"></script>
</body>
</html>
